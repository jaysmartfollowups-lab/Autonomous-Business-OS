{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "moduleResolution": "node",
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "baseUrl": ".",
        "paths": {
            "@tools/*": [
                "Tools/*"
            ],
            "@system/*": [
                "System/*"
            ],
            "@memory/*": [
                "Memory/*"
            ]
        }
    },
    "include": [
        "System/**/*.ts",
        "Tools/**/*.ts",
        "Skills/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "dashboard"
    ]
}